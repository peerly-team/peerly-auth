{
  "ExpirationTimeOptions": {
    "EmailVerificationTokenValidityPeriodMinutes": 10,
    "AccessTokenPeriodMinutes": 15,
    "RefreshTokenPeriodDays": 14
  },
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    }
  },
  "EmailVerificationJob": {
    "BatchSize": 50,
    "MaxFailCount": 3,
    "MaxDegreeOfParallelism": 5,
    "ProcessTimeoutSeconds": 30
  },
  "Smtp": {
    "Host": "smtp.mail.ru",
    "Port": 587,
    "SecurityMode": "SslOnConnect"
  }
}
